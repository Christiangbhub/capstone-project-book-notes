<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add book</title>
    <%- include('partials/header') %>
    <link rel="stylesheet" href="/styles/style.css" />
  </head>
  <body>
    <div class="container my-5">
      <a href="/" class="btn btn-success">Home</a>

      <h1 class="mt-3">Add a book below</h1>
      <form action="/add" method="post">
        <div class="form_data py-3 my-2">
          <div class="form-group">
            <label for="book_title">Book title</label>
            <input
              type="text"
              class="form-control"
              name="book_title"
              required
            />
          </div>
          <div class="form-group">
            <label for="review" class="form-label">Rating</label>
            <select name="review" id="review" required>
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>
          <div class="form-group">
            <label for="date_read" class="form-label">Date Read</label>
            <input type="date" class="form-control" name="date_read" required />
          </div>
          <div class="form-group">
            <label for="comment" class="form-label">Comments</label>
            <textarea
              name="comment"
              id="comment"
              class="form-control"
              placeholder="type here"
              required
            ></textarea>
          </div>
          <div class="form-group">
            <label for="isbn" class="form-label">ISBN</label>
            <input type="number" class="form-control" name="isbn" required />
          </div>
          <input type="submit" value="Add book" class="btn btn-primary" />
        </div>
      </form>
    </div>

    <%- include('partials/footer') %>
  </body>
</html>
